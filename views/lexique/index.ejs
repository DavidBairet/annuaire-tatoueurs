<!doctype html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>

  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/lexique.css">
</head>

<body>

<main class="container lexique">

  <a href="/" class="backLink">← Retour à l'annuaire</a>

  <header class="lexiqueHeader">
    <h1><%= title %></h1>
    <p class="muted">
      Les termes les plus courants dans le monde du tatouage.
    </p>
  </header>


  <section class="lexiqueList">

    <% terms.forEach(term => { %>

      <article class="lexiqueCard">

        <h2><%= term.term %></h2>

        <span class="category">
          <%= term.category %>
        </span>

        <p>
          <%= term.definition %>
        </p>

      </article>

    <% }) %>

  </section>

</main>

</body>
</html>