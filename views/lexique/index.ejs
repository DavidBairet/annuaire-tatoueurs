<!doctype html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>

  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/lexique.css">
</head>

<body>

  <header class="topbar">
    <div class="container topbar__inner">
      <a href="/" class="logo">
        <img src="/images/logo.png" alt="Logo Annuaire" class="logo__img">
        <span class="logo__text">Annuaire</span>
      </a>

      <nav class="menu" aria-label="Navigation principale">
        <a href="/">Accueil</a>
        <a href="/conseils">Conseils</a>
        <a href="/artists/login" class="menu__login">Connexion artiste</a>
        <a href="/artists/apply">Inscription artiste</a>
      </nav>
    </div>
  </header>

  <main class="container lexique">

   

    <header class="lexiqueHeader">
      <h1><%= title %></h1>
      <p class="muted">
        Les termes les plus courants dans le monde du tatouage.
      </p>
    </header>

    <section class="lexiqueList">
      <% terms.forEach(term => { %>
        <article class="lexiqueCard">
          <h2><%= term.term %></h2>

          <span class="category">
            <%= term.category %>
          </span>

          <p>
            <%= term.definition %>
          </p>
        </article>
      <% }) %>
    </section>

  </main>

  <button id="scrollTopBtn" aria-label="Retour en haut">↑</button>

  <script src="/scrollTop.js"></script>
</body>
</html>