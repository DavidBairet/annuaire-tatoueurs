<!doctype html>
<html lang="fr">

<%- include("partials/head", { title: "Accueil - Annuaire de tatoueurs" }) %>

<body class="page--home">

  <%- include("partials/header") %>

  <main>

    <section class="hero">
      <div class="container hero__inner">
        <h1>Trouve ton tatoueur ou ton pierceur</h1>

        <p>
          Explore les artistes par ville et style, consulte leurs profils et contacte-les facilement.
        </p>

        <form class="search" action="/artists" method="GET">
          <input
            class="search__input"
            type="search"
            name="q"
            placeholder="Chercher un tatoueur (nom, ville, style...)"
            autocomplete="off"
          >

          <button class="search__btn" type="submit">
            Rechercher
          </button>
        </form>

        <div class="hero__actions">
          <a class="btn btn--primary" href="/artists">
            Voir les tatoueurs
          </a>
        </div>
      </div>
    </section>

    <section class="inkheart-banner">
      <img
        src="/images/inkheart.png"
        alt="Tatouage thérapeutique sur cicatrice - Ink Heart"
      >

      <div class="inkheart-links">
        <p>Association partenaire engagée dans le tatouage thérapeutique</p>

        <div class="inkheart-socials">
          <a
            href="https://www.facebook.com/ink.heart.tatouage.sur.cicatrice.2025"
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn facebook"
          >
            <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M22 12a10 10 0 1 0-11.5 9.9v-7h-2.3v-2.9h2.3V9.8c0-2.3 1.4-3.6 3.5-3.6 1 0 2 .2 2 .2v2.2h-1.2c-1.2 0-1.6.8-1.6 1.5v1.8h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/>
            </svg>
            Facebook
          </a>

          <a
            href="https://www.instagram.com/inkheart_isj"
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn instagram"
          >
            <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm5 3.5A4.5 4.5 0 1 1 12 16a4.5 4.5 0 0 1 0-9zm0 2A2.5 2.5 0 1 0 12 14a2.5 2.5 0 0 0 0-5zm5.25-3a1.25 1.25 0 1 1-1.25 1.25 1.25 1.25 0 0 1 1.25-1.25z"/>
            </svg>
            Instagram
          </a>
        </div>

     <div class="site-pro-card">
  <div class="site-pro-card__content">
    <p class="site-pro-card__eyebrow">Pour les artistes tatoueurs & pierceurs</p>

    <h2>Besoin d’un site vitrine professionnel ?</h2>

    <p>
      Je crée des sites clairs, modernes et accessibles pour présenter ton salon,
      tes réalisations et attirer plus de clients.
    </p>
  </div>

  <div class="site-pro-card__actions">
    <a href="https://les-sites-de-david.fr/" target="_blank" rel="noopener noreferrer" class="site-pro-card__btn site">
      Voir mon site pro
    </a>

    <a href="https://www.instagram.com/lessitesdedavid/" target="_blank" rel="noopener noreferrer" class="site-pro-card__btn instagram">
      Instagram
    </a>

    <a href="https://www.facebook.com/profile.php?id=61578401889941&locale=fr_FR" target="_blank" rel="noopener noreferrer" class="site-pro-card__btn facebook">
      Facebook
    </a>
  </div>
</div>
      </div>
    </section>

    <section class="ctaPremium">
      <div class="container">
        <div class="ctaPremium__card">
          <h2 class="ctaPremium__title">
            Tu es tatoueur ou perceur ?
          </h2>

          <p class="ctaPremium__subtitle">
            Rejoignez l’annuaire et développez votre visibilité, présentez votre art et attirez de nouveaux clients près de chez vous.
          </p>

          <div class="ctaPremium__benefits">
            <div class="benefit">✓ Profil professionnel dédié</div>
            <div class="benefit">✓ Présentez vos styles et vos réseaux</div>
            <div class="benefit">✓ Contact direct avec vos futurs clients</div>
            <div class="benefit">✓ Inscription gratuite</div>
          </div>

          <div class="ctaPremium__actions">
            <a href="/artists/apply" class="btn btn--primary">
              S’inscrire gratuitement
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <%- include("partials/footer") %>

</body>
</html>