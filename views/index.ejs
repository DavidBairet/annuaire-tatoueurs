<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Annuaire de tatoueurs</title>

  <link rel="stylesheet" href="/styles.css" />
  <link rel="icon" href="/images/logo.png">

</head>

<body class="page--home">

<header class="topbar">
  <div class="container topbar__inner">

    <a class="logo" href="/">
      <img src="/images/logo.png" alt="" class="logo__img">
      <span class="logo__text">Annuaire</span>
    </a>

    <nav class="menu">
      
      <a href="/conseils">Conseils</a>
      <a href="/lexique">Lexique</a>
      <a href="/artists/apply">Inscription artiste</a>
    </nav>

  </div>
</header>


<main>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">

      <h1>Trouve ton tatoueur ou ton pierceur</h1>

      <p>
        Explore les artistes par ville et style, consulte leurs profils et contacte-les facilement.
      </p>

      <form class="search" action="/artists" method="GET">

        <input
          class="search__input"
          type="search"
          name="q"
          placeholder="Chercher un tatoueur (nom, ville, style...)"
          autocomplete="off"
        />

        <button class="search__btn" type="submit">
          Rechercher
        </button>

      </form>

      <div class="hero__actions">
        <a class="btn btn--primary" href="/artists">
          Voir les tatoueurs
        </a>

       
      </div>

    </div>
  </section>


  <!-- CTA PREMIUM ARTISTES -->
  <section class="ctaPremium">
    <div class="container">

      <div class="ctaPremium__card">

        <h2 class="ctaPremium__title">
          Tu es tatoueur ou perceur ?
        </h2>

        <p class="ctaPremium__subtitle">
          Rejoignez l’annuaire et développez votre visibilité, présentez votre art et attirez de nouveaux clients près de chez vous.
        </p>

        <div class="ctaPremium__benefits">

          <div class="benefit">✓ Profil professionnel dédié</div>
          <div class="benefit">✓ Présentez vos styles et vos réseaux</div>
          <div class="benefit">✓ Contact direct avec vos futurs clients</div>
          <div class="benefit">✓ Inscription gratuite</div>

        </div>

        <div class="ctaPremium__actions">

          <a href="/artists/apply" class="btn btn--primary">
            S’inscrire gratuitement
          </a>

          <a href="/artists" class="btn btn--ghost">
            Voir les tatoueurs
          </a>

        </div>

      </div>

    </div>
  </section>

</main>


<footer class="footer">
  <div class="container">
    <small>
      © <%= new Date().getFullYear() %> — Annuaire de tatoueurs
    </small>
  </div>
</footer>


</body>
</html>