<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>

  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/inscription.css">
</head>

<body class="page--apply">

  <header class="topbar topbar--minimal">
    <div class="container topbar__inner">
      <a class="logo logo--center" href="/">
        <img src="/images/logo.png" alt="Logo Annuaire" class="logo__img">
        <span class="logo__text">Retour à l'Annuaire</span>
      </a>
    </div>
  </header>

  <main class="applySection">
    <div class="container">
      <form class="applyForm" method="POST" action="/artists/login">
        <h1>Connexion artiste</h1>

        <% if (error) { %>
          <p class="formError"><%= error %></p>
        <% } %>

        <label for="email">Email</label>
        <input
          name="email"
          id="email"
          type="email"
          required
        >

        <label for="password">Mot de passe</label>

        <div class="passwordField">
          <input
            name="password"
            id="password"
            type="password"
            required
          >

          <button
            type="button"
            class="togglePassword"
            aria-label="Afficher le mot de passe"
          >
            👁
          </button>
        </div>

        <button type="submit" class="submitBtn">
          Se connecter
        </button>
      </form>
    </div>
  </main>

 <script src="/login.js"></script>
  

</body>
</html>