<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>

  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/inscription.css">
</head>

<body class="page--apply">

  <header class="topbar topbar--minimal">
    <div class="container topbar__inner">
      <a class="logo logo--center" href="/">
        <img src="/images/logo.png" alt="Logo Annuaire" class="logo__img">
        <span class="logo__text">Retour à l'Annuaire</span>
      </a>
    </div>
  </header>

  <main class="applySection">
    <div class="container">
      <form
        class="applyForm"
        method="POST"
        action="<%= token ? `/artists/reset-password/${token}` : '#' %>"
      >
        <h1>Réinitialiser le mot de passe</h1>

        <% if (error) { %>
          <p class="formError"><%= error %></p>
        <% } %>

        <% if (success) { %>
          <p style="color: #7bd88f; margin-bottom: 16px;"><%= success %></p>
          <p style="text-align:center;">
            <a href="/artists/login">Retour à la connexion</a>
          </p>
        <% } %>

        <% if (token) { %>
          <label for="password">Nouveau mot de passe</label>
          <input
            name="password"
            id="password"
            type="password"
            required
          >

          <label for="confirmPassword">Confirmer le mot de passe</label>
          <input
            name="confirmPassword"
            id="confirmPassword"
            type="password"
            required
          >

          <button type="submit" class="submitBtn">
            Mettre à jour le mot de passe
          </button>
        <% } %>
      </form>
    </div>
  </main>

</body>
</html>