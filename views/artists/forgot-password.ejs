<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>

  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/inscription.css">
</head>

<body class="page--apply">

  <header class="topbar topbar--minimal">
    <div class="container topbar__inner">
      <a class="logo logo--center" href="/">
        <img src="/images/logo.png" alt="Logo Annuaire" class="logo__img">
        <span class="logo__text">Retour à l'Annuaire</span>
      </a>
    </div>
  </header>

  <main class="applySection">
    <div class="container">
      <form class="applyForm" method="POST" action="/artists/forgot-password">
        <h1>Mot de passe oublié</h1>

        <p>
          Entrez votre adresse email pour recevoir un lien de réinitialisation.
        </p>

        <% if (error) { %>
          <p class="formError"><%= error %></p>
        <% } %>

        <% if (success) { %>
          <p style="color: #7bd88f; margin-bottom: 16px;"><%= success %></p>
        <% } %>

        <% if (typeof resetUrl !== "undefined" && resetUrl) { %>
          <p style="margin-bottom: 16px;">
            <a href="<%= resetUrl %>">Lien de test de réinitialisation</a>
          </p>
        <% } %>

        <label for="email">Email</label>
        <input
          name="email"
          id="email"
          type="email"
          required
        >

        <button type="submit" class="submitBtn">
          Envoyer le lien
        </button>

        <p style="margin-top:16px; text-align:center;">
          <a href="/artists/login">Retour à la connexion</a>
        </p>
      </form>
    </div>
  </main>

</body>
</html>