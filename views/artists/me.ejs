<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<header class="topbar">
  <div class="container topbar__inner">

    <a class="logo" href="/">
      <img src="/images/logo.png" alt="Logo Annuaire" class="logo__img">
      <span class="logo__text">Retour à l'Annuaire</span>
    </a>

    <div style="margin-left:auto; display:flex; gap:10px; align-items:center;">
      <span style="opacity:.8; font-size:.9rem;"><%= artist.email %></span>

      <form action="/artists/logout" method="POST" style="margin:0;">
        <button class="btn btn--ghost" type="submit">Déconnexion</button>
      </form>
    </div>

  </div>
</header>

<main class="section">
  <div class="container">

    <h1 class="pageTitle">Espace artiste</h1>
    <p class="pageSub">
      Bienvenue <strong><%= artist.name || "Artiste" %></strong>
    </p>

    <div class="card" style="margin-top:16px;">

      <h2 style="margin-top:0;">Ma fiche</h2>

      <p><strong>Email :</strong> <%= artist.email %></p>
      <p><strong>Ville :</strong> <%= artist.city || "-" %></p>
      <p><strong>Département :</strong> <%= artist.department || "-" %></p>

      <p>
        <strong>Styles :</strong>
        <%= (artist.styles && artist.styles.length) ? artist.styles.join(", ") : "-" %>
      </p>

      <p>
        <strong>Instagram :</strong>
        <% if (artist.instagram) { %>
          <a href="<%= artist.instagram %>" target="_blank" rel="noreferrer"><%= artist.instagram %></a>
        <% } else { %>
          -
        <% } %>
      </p>

      <p>
        <strong>Bio :</strong><br>
        <%= artist.bio || "—" %>
      </p>

      <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
        <a class="btn" href="/artists/me/edit">Modifier ma fiche</a>
        <a class="btn btn--ghost" href="/artists/me/delete">Supprimer mon compte</a>
      </div>

      <hr style="margin:18px 0; opacity:.25;">

      <h3 style="margin:0 0 10px;">Galerie</h3>

      <form action="/artists/me/upload" method="POST" enctype="multipart/form-data" style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <input type="file" name="image" accept="image/*" required>
        <button class="btn" type="submit">Ajouter une photo</button>
      </form>

      <% if (artist.gallery && artist.gallery.length) { %>
        <div style="margin-top:16px; display:grid; grid-template-columns:repeat(auto-fill,150px); gap:10px;">
          <% artist.gallery.forEach((img) => { %>
            <div style="position:relative; width:150px; height:150px;">
              <img
                src="<%= img %>"
                alt="Tatouage"
                style="width:150px; height:150px; object-fit:cover; border-radius:10px;"
              >
              <form action="/artists/me/gallery/delete" method="POST" style="position:absolute; top:6px; right:6px; margin:0;">
                <input type="hidden" name="img" value="<%= img %>">
                <button type="submit" class="btn btn--ghost" style="padding:6px 10px; line-height:1;">✕</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p style="margin-top:12px; opacity:.8;">Aucune photo pour le moment.</p>
      <% } %>

    </div>

  </div>
</main>

</body>
</html>