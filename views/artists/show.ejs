<!DOCTYPE html>
<html lang="fr">
  <%- include("../partials/head", { title: artist.name, css: "/artists.css" }) %>

  <body class="page--artist">

    <!-- Header minimal (pas le gros hero) -->
    <header class="topbar topbar--minimal">
      <div class="container topbar__inner">
        <a class="logo logo--center" href="/">
          <img src="/images/logo.png" alt="Logo Annuaire" class="logo__img">
          <span class="logo__text">Accueil</span>
        </a>
      </div>
    </header>

    <main class="artistProfile container">

      <section class="artistCard">

        <!-- HEADER -->
        <header class="artistHeader">

          <div class="artistAvatar">
            <% if (artist.avatar) { %>
              <img src="<%= artist.avatar %>" alt="<%= artist.name %>">
            <% } else { %>
              <div class="avatarPlaceholder">
                <%= artist.name.charAt(0).toUpperCase() %>
              </div>
            <% } %>
          </div>

          <div class="artistInfo">

            <h1 class="artistName"><%= artist.name %></h1>

            <p class="artistCity">
              📍
              <%= artist.postalCode ? artist.postalCode : "" %>
              <%= artist.city || "Ville non renseignée" %>
              <% if (artist.department) { %>
                <span class="artistDept">(<%= artist.department %>)</span>
              <% } %>
            </p>

            <% if (artist.styles && artist.styles.length) { %>
              <div class="artistStyles">
                <% artist.styles.forEach(style => { %>
                  <span class="styleTag"><%= style %></span>
                <% }) %>
              </div>
            <% } %>

            <div class="artistLinks">
              <% if (artist.instagram) { %>
                <a href="<%= artist.instagram %>" target="_blank" class="btnInstagram">
                  Instagram
                </a>
              <% } %>

              <% if (artist.facebook) { %>
                <a href="<%= artist.facebook %>" target="_blank" class="btnLink">
                  Facebook
                </a>
              <% } %>

              <% if (artist.website) { %>
                <a href="<%= artist.website %>" target="_blank" class="btnLink">
                  Site web
                </a>
              <% } %>
            </div>

          </div>

        </header>


        <!-- BIO -->
        <section class="artistBio">
          <h2>À propos</h2>
          <p><%= artist.bio || "Ce tatoueur n'a pas encore ajouté de description." %></p>
        </section>


        <!-- INFOS PRATIQUES -->
        <section class="artistDetails">

          <h2>Infos pratiques</h2>

          <div class="detailGrid">

            <!-- ADRESSE -->
            <div class="detailItem">
              <h3>Adresse</h3>
              <% if (artist.address1 || artist.address2 || artist.city) { %>
                <p>
                  <% if (artist.address1) { %><%= artist.address1 %><br><% } %>
                  <% if (artist.address2) { %><%= artist.address2 %><br><% } %>
                  <%= artist.postalCode ? artist.postalCode : "" %>
                  <%= artist.city ? artist.city : "" %>
                </p>
              <% } else { %>
                <p class="muted">Adresse non renseignée</p>
              <% } %>
            </div>

            <!-- TELEPHONE -->
            <div class="detailItem">
              <h3>Téléphone</h3>
              <% if (artist.phone) { %>
                <p><a href="tel:<%= artist.phone %>"><%= artist.phone %></a></p>
              <% } else { %>
                <p class="muted">Téléphone non renseigné</p>
              <% } %>
            </div>

            <!-- EMAIL -->
            <div class="detailItem">
              <h3>Email</h3>
              <% if (artist.email) { %>
                <p><a href="mailto:<%= artist.email %>"><%= artist.email %></a></p>
              <% } else { %>
                <p class="muted">Email non renseigné</p>
              <% } %>
            </div>

          </div>

        </section>


        <!-- META -->
        <footer class="artistMeta">
          <span>
            Inscrit le :
            <%= new Date(artist.createdAt).toLocaleDateString("fr-FR") %>
          </span>
        </footer>

      </section>

    </main>

    <%- include("../partials/footer") %>
  </body>
</html>